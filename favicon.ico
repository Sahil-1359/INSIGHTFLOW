        (function() {
          try {
            // Always set light theme initially to prevent FOUC
            // User theme will be applied later by React components based on auth and route
            document.documentElement.setAttribute('data-theme', 'light');
            document.documentElement.setAttribute('data-color-mode', 'light');
            document.documentElement.classList.remove('dark');
          } catch (e) {
            // Fallback to light theme if anything goes wrong
            document.documentElement.setAttribute('data-theme', 'light');
            document.documentElement.setAttribute('data-color-mode', 'light');
            document.documentElement.classList.remove('dark');
          }
        })();
      </script><!--$--><div class="flex flex-col h-[100vh] max-sm:h-full" data-sentry-component="Playground" data-sentry-source-file="page.tsx"><div class="bg-black px-2 py-1.5 flex justify-between max-sm:flex-col max-sm:gap-2" data-sentry-component="BuilderHeader" data-sentry-source-file="index.tsx"><div class="flex gap-2 items-center  max-sm:!w-full" style="width: 480px;"><button data-tooltip-id="launchpad" class="relative flex items-center justify-center cursor-pointer bg-surface-button-onColor-subtle text-onColor-heading hover:bg-surface-button-onColor-subtle-hover disabled:hover:bg-surface-button-onColor-subtle w-[32px] h-[32px] rounded-9 disabled:opacity-80 disabled:text-disabled-default focus:outline-none disabled:cursor-not-allowed shrink-0 rightAnimation" aria-disabled="false" aria-busy="false" data-sentry-element="Button" data-sentry-source-file="index.tsx"><div class="w-full flex items-center justify-center"><div class="flex items-center justify-center gap-1"><div class="w-[18px] h-[18px] flex justify-center items-center"><svg xmlns="http://www.w3.org/2000/svg" width="100%" height="100%" fill="currentColor" viewBox="0 0 256 256" data-sentry-element="HouseIcon" data-sentry-source-file="index.tsx"><path d="M219.31,108.68l-80-80a16,16,0,0,0-22.62,0l-80,80A15.87,15.87,0,0,0,32,120v96a8,8,0,0,0,8,8h64a8,8,0,0,0,8-8V160h32v56a8,8,0,0,0,8,8h64a8,8,0,0,0,8-8V120A15.87,15.87,0,0,0,219.31,108.68ZM208,208H160V152a8,8,0,0,0-8-8H104a8,8,0,0,0-8,8v56H48V120l80-80,80,80Z"></path></svg></div></div></div></button><div class="focus:outline-none min-w-[320px] max-w-[320px] max-sm:w-full max-sm:min-w-auto justify-between bg-surface-button-onColor-subtle text-onColor-heading py-[7px] h-[32px] px-3 rounded-10 cursor-pointer max-sm:overflow-hidden" type="button" id="radix-«r0»" aria-haspopup="menu" aria-expanded="false" data-state="closed" data-sentry-element="unknown" data-sentry-source-file="ProjectDropdown.tsx"><div class="flex gap-2 w-full items-center justify-between"><div